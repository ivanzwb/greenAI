.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 24rpx;
  line-height: 1.35;
}

.body {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.65;
  white-space: pre-wrap;
}

.empty {
  padding: 48rpx;
  text-align: center;
  color: #888;
  font-size: 28rpx;
}
