<view class="ga-page diagnose">
  <view class="ga-hero diagnose-hero">
    <view class="ga-hero__title">问题诊断</view>
    <view class="ga-hero__desc">可拍照评估盆土干湿度与肥力，或勾选症状做规则参考。结果仅供参考。</view>
  </view>

  <view class="diagnose-expert ga-card">
    <text class="diagnose-expert__title">人工 / 专家</text>
    <text class="diagnose-expert__body">复杂病虫害或整株萎蔫时，建议联系线下园艺师或平台客服，并附上清晰照片与环境说明。</text>
    <button class="diagnose-contact-btn" open-type="contact" session-from="diagnose">联系客服</button>
    <text class="diagnose-expert__note">需在小程序后台开通「客服」后，按钮才会接入会话。</text>
  </view>

  <view wx:if="{{llmDiagnoseEnabled}}" class="diagnose-panel ga-card" id="soil-panel">
    <text class="diagnose-panel__title soil-panel__title">🪴 土壤诊断</text>
    <text class="diagnose-panel__hint">拍摄盆土特写照片，AI 评估干湿度与肥力状态</text>
    <text class="diagnose-panel__hint">{{llmImageLabel}}</text>
    <view class="diagnose-row-btns">
      <view class="diagnose-btn diagnose-btn--primary" bindtap="onPickImage">选择 / 拍摄盆土照片</view>
      <view class="diagnose-btn diagnose-btn--ghost {{!llmImageBase64 ? 'diagnose-btn--disabled' : ''}}" bindtap="onSubmitLlm">评估土壤</view>
    </view>
  </view>
  <view wx:else class="diagnose-muted ga-card">当前未启用视觉大模型诊断（服务器未配置 DIAGNOSE_LLM_API_KEY）。仍可使用下方规则诊断。</view>

  <!-- 土壤诊断结果 -->
  <view wx:if="{{soilResult}}" class="diagnose-soil-result ga-card">
    <text class="diagnose-soil-result__title">土壤评估结果</text>
    <view class="diagnose-soil__row">
      <text class="diagnose-soil__label">干湿度</text>
      <text class="diagnose-soil__tag diagnose-soil__tag--{{soilResult.moistureKey}}">{{soilResult.moistureLabel}}</text>
      <text wx:if="{{soilResult.confidence}}" class="diagnose-soil__conf">置信度 {{soilResult.confidence}}%</text>
    </view>
    <view class="diagnose-soil__row">
      <text class="diagnose-soil__label">肥力</text>
      <text class="diagnose-soil__tag diagnose-soil__tag--fertility">{{soilResult.fertilityLabel}}</text>
    </view>
    <view wx:if="{{soilResult.rationale}}" class="diagnose-soil__block">
      <text class="diagnose-soil__subtitle">分析依据</text>
      <text class="diagnose-soil__text">{{soilResult.rationale}}</text>
    </view>
    <view wx:if="{{soilResult.wateringTip}}" class="diagnose-soil__block">
      <text class="diagnose-soil__subtitle">养护建议</text>
      <text class="diagnose-soil__text diagnose-soil__tip">{{soilResult.wateringTip}}</text>
    </view>
  </view>

  <view class="ga-section-title">规则诊断</view>
  <view class="diagnose-panel ga-card">
    <view class="diagnose-field">
      <text class="diagnose-label">关联植物（可选）</text>
      <picker mode="selector" range="{{plantLabels}}" value="{{plantPickerIndex}}" bindchange="onPlantPickerChange">
        <view class="diagnose-picker">{{plantLabels[plantPickerIndex]}}</view>
      </picker>
    </view>

    <checkbox-group bindchange="onSymptomChange">
      <block wx:for="{{symptomGroups}}" wx:key="group">
        <text class="diagnose-group-title">{{item.group}}</text>
        <label wx:for="{{item.items}}" wx:for-item="sym" wx:key="id" class="diagnose-symptom">
          <checkbox value="{{sym.id}}" checked="{{sym.checked}}" color="#2a4d3a" />
          <text class="diagnose-symptom__text">{{sym.label}}</text>
        </label>
      </block>
    </checkbox-group>

    <view class="diagnose-submit {{submitDisabled ? 'diagnose-submit--disabled' : ''}}" bindtap="onSubmit">生成参考意见</view>
  </view>

  <view wx:if="{{result}}" class="diagnose-result">
    <view class="ga-section-title">参考意见</view>
    <block wx:for="{{result.causes}}" wx:key="id">
      <view class="diagnose-cause ga-card">
        <text class="diagnose-cause__title">{{item.title}}</text>
        <text class="diagnose-cause__summary">{{item.summary}}</text>
        <block wx:for="{{item.actions}}" wx:for-item="act" wx:key="*this">
          <text class="diagnose-action-line">· {{act}}</text>
        </block>
      </view>
    </block>
    <block wx:for="{{result.contextTips}}" wx:key="*this">
      <view class="diagnose-tip">{{item}}</view>
    </block>
    <view wx:if="{{result.relatedArticles && result.relatedArticles.length}}" class="diagnose-kb ga-card">
      <text class="diagnose-kb__title">延伸阅读</text>
      <view wx:for="{{result.relatedArticles}}" wx:key="slug" class="diagnose-kb__row" data-slug="{{item.slug}}" bindtap="onOpenKnowledgeArticle">
        <text class="diagnose-kb__row-title">{{item.title}}</text>
        <text wx:if="{{item.summary}}" class="diagnose-kb__row-sum">{{item.summary}}</text>
      </view>
    </view>
    <text class="diagnose-disclaimer">{{result.disclaimer}}</text>
  </view>
</view>
