.plant-plan-hero {
  margin-bottom: var(--ga-space-lg);
}

.plant-plan-actions {
  padding: 20rpx 24rpx;
  margin-bottom: var(--ga-space);
}

.plant-plan-refresh {
  display: inline-flex;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-brand);
  border: 1rpx solid var(--ga-border-strong);
}

.plant-plan-muted,
.plant-plan-empty {
  padding: 28rpx;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
}

.plant-plan-row {
  padding: 24rpx 28rpx;
  margin-bottom: var(--ga-space);
}

.plant-plan-row__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.plant-plan-type {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ga-text);
}

.plant-plan-status {
  font-size: 24rpx;
  color: var(--ga-text-muted);
}

.plant-plan-due {
  font-size: 24rpx;
  color: var(--ga-text-secondary);
  font-variant-numeric: tabular-nums;
}
