/* ── 天气大卡 ── */

.index-weather-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: var(--ga-space-lg);
  overflow: hidden;
}

.index-weather-hero--empty .index-weather-hero__placeholder {
  color: var(--ga-text-secondary);
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.index-weather-hero__left {
  flex: 1;
  min-width: 0;
}

.index-weather-hero__date {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ga-text-muted);
  margin-bottom: 8rpx;
}

.index-weather-hero__temp-row {
  margin-bottom: 8rpx;
}

.index-weather-hero__big-temp {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--ga-text);
  letter-spacing: -0.03em;
}

.index-weather-hero__humid {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  margin-bottom: 8rpx;
}

.index-weather-hero__cond {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text);
  margin-bottom: 8rpx;
}

.index-weather-hero__hint {
  display: block;
  font-size: 24rpx;
  color: var(--ga-brand);
  font-weight: 600;
}

.index-weather-hero__sun-img {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
  align-self: center;
}

.index-weather-hero__sun-img--muted {
  opacity: 0.75;
}

/* ── 区块标题 ── */

.index-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.index-section-head__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ga-text);
}

.index-section-head__title--solo {
  display: block;
  margin: var(--ga-space-lg) 0 16rpx;
}

.index-section-head__link {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-brand);
}

/* ── 待办圆环 ── */

.index-todos-row {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx 28rpx;
  margin-bottom: var(--ga-space-lg);
}

.index-donut-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.index-donut {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border: 12rpx solid #e3f2fd;
  background: #fafafa;
}

.index-donut__glyph {
  width: 44rpx;
  height: 44rpx;
}

.index-donut__num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--ga-text);
  line-height: 1.1;
}

.index-donut--water {
  border-color: #90caf9;
  background: #e3f2fd;
}

.index-donut--fert {
  border-color: #ffcc80;
  background: #fff3e0;
}

.index-donut__cap {
  font-size: 24rpx;
  color: var(--ga-text-secondary);
  font-weight: 600;
}

/* ── 植物横滑 ── */

.index-plants-scroll {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  margin-bottom: var(--ga-space-lg);
}

.index-plants-scroll__inner {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-start;
  gap: 20rpx;
  padding: 4rpx 4rpx 16rpx;
  width: max-content;
  min-height: 150rpx;
}

.index-plant-chip {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 132rpx;
}

.index-plant-chip__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: var(--ga-brand-soft);
  color: var(--ga-brand);
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  border: 1rpx solid var(--ga-border);
}

.index-plant-chip__name {
  font-size: 22rpx;
  color: var(--ga-text-secondary);
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.index-plants-empty {
  padding: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  margin-bottom: var(--ga-space-lg);
}

/* ── 常用工具（三宫格） ── */

.index-tools {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 16rpx 24rpx;
  margin-bottom: var(--ga-space-lg);
}

.index-tool {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  border-radius: var(--ga-radius-md);
  background: var(--ga-bg-elevated);
  border: 1rpx solid var(--ga-border);
}

.index-tool:active {
  opacity: 0.92;
}

.index-tool__icon-img {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 10rpx;
}

.index-tool__label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ga-text-secondary);
  text-align: center;
}

/* ── Hero（旧版已弃用，保留类名防引用断裂） ── */

/* ── Tasks ── */

.index-task {
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: var(--ga-space);
  border-left: 6rpx solid var(--ga-brand);
}

.index-task__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.index-task__time {
  font-size: 24rpx;
  color: var(--ga-text-muted);
  font-variant-numeric: tabular-nums;
}

.index-task__plant {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ga-text);
  letter-spacing: -0.02em;
  margin-bottom: 24rpx;
}

.index-task__foot {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

/* ── Badge ── */

.index-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.index-badge--water {
  background: var(--ga-water-soft);
  color: var(--ga-water);
}

.index-badge--fertilize {
  background: var(--ga-fertilize-soft);
  color: var(--ga-fertilize);
}

.index-badge--other {
  background: var(--ga-brand-soft);
  color: var(--ga-brand);
}

/* ── Pill buttons ── */

.index-pill {
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  min-width: 160rpx;
}

.index-pill--primary {
  background: var(--ga-brand);
  color: #ffffff;
}

.index-pill--quiet {
  background: transparent;
  color: var(--ga-text-secondary);
  border: 1rpx solid var(--ga-border-strong);
}

/* ── Empty state ── */

.index-empty {
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: var(--ga-space-lg);
}

.index-empty__mark {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ga-brand-soft);
  background: linear-gradient(145deg, var(--ga-brand-soft), transparent);
}

.index-empty__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ga-text);
  margin-bottom: 12rpx;
}

.index-empty__hint {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
  margin-bottom: 24rpx;
}

.index-empty__act {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  background: var(--ga-brand);
  color: #f6fffa;
  font-size: 26rpx;
  font-weight: 600;
}

/* ── Quick actions ── */

.index-actions {
  margin-top: var(--ga-space-lg);
  margin-bottom: var(--ga-space);
  padding: 16rpx;
}

.index-actions__row {
  display: flex;
  gap: 12rpx;
}

.index-actions__row + .index-actions__row {
  margin-top: 12rpx;
}

.index-act {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
  cursor: pointer;
  transition: background 0.15s;
}

.index-act:active {
  filter: brightness(0.92);
}

.index-act--identify,
.index-act--soil,
.index-act--symptom {
  background: var(--ga-brand-soft);
}

.index-act--full {
  flex: none;
  width: 100%;
  background: var(--ga-brand);
  color: #f6fffa;
  border-color: var(--ga-brand);
}

.index-act--full .index-act__icon,
.index-act--full .index-act__label {
  color: #f6fffa;
}

.index-act__icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.index-act__label {
  font-size: 26rpx;
  font-weight: 600;
}


