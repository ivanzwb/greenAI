.index .index-toolbar {
  padding: 24rpx;
  margin-bottom: var(--ga-space-lg);
}

.index-toolbar__row {
  display: flex;
  gap: 12rpx;
}

.index-toolbar__row--cta {
  margin-top: 16rpx;
}

/* ── icon button ── */

.index-ibtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 8rpx;
  border-radius: var(--ga-radius-sm);
  background: var(--ga-bg-elevated);
  border: 1rpx solid var(--ga-border-strong);
  color: var(--ga-text);
  font-weight: 600;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.2;
}

.index-ibtn__icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.index-ibtn__label {
  white-space: nowrap;
}

/* ── brand CTA ── */

.index-ibtn--brand {
  background: var(--ga-brand);
  color: #f4faf6;
  border-color: var(--ga-brand);
  border-radius: var(--ga-radius-sm);
  font-size: 26rpx;
  padding: 18rpx 24rpx;
}

.index-empty {
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: var(--ga-space-lg);
}

.index-empty__mark {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ga-brand-soft);
  background: linear-gradient(145deg, var(--ga-brand-soft), transparent);
}

.index-empty__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ga-text);
  margin-bottom: 12rpx;
}

.index-empty__hint {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
}

.index-task {
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: var(--ga-space);
  border-left: 6rpx solid var(--ga-brand-mid);
}

.index-task__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.index-task__due {
  font-size: 24rpx;
  color: var(--ga-text-muted);
  font-variant-numeric: tabular-nums;
}

.index-task__plant {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ga-text);
  letter-spacing: -0.02em;
  margin-bottom: 24rpx;
}

.index-task__foot {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.index-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.index-badge--water {
  background: var(--ga-water-soft);
  color: var(--ga-water);
}

.index-badge--fertilize {
  background: var(--ga-fertilize-soft);
  color: var(--ga-fertilize);
}

.index-badge--other {
  background: var(--ga-brand-soft);
  color: var(--ga-brand);
}

.index-pill {
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  min-width: 160rpx;
}

.index-pill--primary {
  background: var(--ga-brand);
  color: #f6fffa;
}

.index-pill--quiet {
  background: transparent;
  color: var(--ga-text-secondary);
  border: 1rpx solid var(--ga-border-strong);
}
