<view class="ga-page index">
  <!-- ======== Hero ======== -->
  <view class="index-hero">
    <text class="ga-hero__eyebrow">{{heroDate}} · {{weekday}}</text>
    <view class="index-hero__greeting">{{greeting}}</view>
    <text class="index-hero__summary">{{summaryText}}</text>
  </view>

  <!-- ======== 养护 section ======== -->
  <text class="index-section-title">🌱 养护</text>

  <!-- ======== Stats row ======== -->
  <view class="index-stats">
    <view class="index-stat ga-card" bindtap="goPlants">
      <text class="index-stat__num">{{plantCount}}</text>
      <text class="index-stat__label">植物</text>
    </view>
    <view class="index-stat ga-card">
      <text class="index-stat__num index-stat__num--accent">{{pendingCount}}</text>
      <text class="index-stat__label">待办</text>
    </view>
    <view class="index-stat ga-card" bindtap="goDiagnose">
      <text class="index-stat__num index-stat__num--warn">{{attentionCount}}</text>
      <text class="index-stat__label">需关注</text>
    </view>
  </view>

  <!-- ======== Weather ======== -->
  <view wx:if="{{weatherCurrent}}" class="index-weather ga-card">
    <view class="index-weather__head">
      <text class="index-weather__icon">🌤</text>
      <text class="index-weather__temp">{{weatherCurrent.temperatureC}}°C</text>
      <text class="index-weather__sep">·</text>
      <text class="index-weather__humid">湿度 {{weatherCurrent.relativeHumidity}}%</text>
    </view>
    <view wx:if="{{forecastDays && forecastDays.length}}" class="index-forecast">
      <view wx:for="{{forecastDays}}" wx:key="date" class="index-forecast__day">
        <text class="index-forecast__dow">{{item.dow}}</text>
        <text class="index-forecast__icon">{{item.wmoIcon}}</text>
        <text class="index-forecast__t">{{item.tempMinC}}° / {{item.tempMaxC}}°</text>
      </view>
    </view>
  </view>
  <view wx:else class="index-weather ga-card index-weather--empty" bindtap="goPlants">
    <text class="index-weather__placeholder">🌍 保存位置后可查看本地天气</text>
  </view>

  <!-- ======== 待办区域 ======== -->
  <block wx:if="{{tasks.length > 0}}">
    <text class="index-section-title">📋 待办</text>
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="index-task ga-card">
        <view class="index-task__head">
          <view class="index-badge index-badge--{{item.typeClass}}">{{item.displayType}}</view>
          <text class="index-task__time">{{item.displayTime}}</text>
        </view>
        <text class="index-task__plant">{{item.plantNickname}}</text>
        <view class="index-task__foot">
          <view class="index-pill index-pill--primary" data-id="{{item.id}}" bindtap="onComplete">标记完成</view>
          <view class="index-pill index-pill--quiet" data-id="{{item.id}}" bindtap="onSkip">跳过</view>
        </view>
      </view>
    </block>
  </block>

  <!-- ======== Quick actions ======== -->
  <view class="index-actions ga-card">
    <view class="index-actions__row">
      <view class="index-act index-act--identify" bindtap="onIdentify">
        <text class="index-act__icon">🌼</text>
        <text class="index-act__label">拍照识花</text>
      </view>
      <view class="index-act index-act--soil" bindtap="onDiagnosePhoto">
        <text class="index-act__icon">🪴</text>
        <text class="index-act__label">土壤诊断</text>
      </view>
      <view class="index-act index-act--symptom" bindtap="onDiagnoseSymptom">
        <text class="index-act__icon">📋</text>
        <text class="index-act__label">症状诊断</text>
      </view>
    </view>
    <view class="index-actions__row">
      <view class="index-act index-act--full" bindtap="goAdd">
        <text class="index-act__icon">＋</text>
        <text class="index-act__label">添加植物</text>
      </view>
    </view>
  </view>
</view>
