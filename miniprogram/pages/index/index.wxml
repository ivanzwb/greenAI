<view class="ga-page index">
  <!-- 天气大卡（对齐设计稿顶部） -->
  <view wx:if="{{weatherCurrent}}" class="index-weather-hero ga-card">
    <view class="index-weather-hero__left">
      <text class="index-weather-hero__date">{{heroDate}} · {{weekday}}</text>
      <view class="index-weather-hero__temp-row">
        <text class="index-weather-hero__big-temp">{{weatherCurrent.temperatureC}}°C</text>
      </view>
      <text class="index-weather-hero__humid">湿度 {{weatherCurrent.relativeHumidity}}%</text>
      <text wx:if="{{weatherSummaryLine}}" class="index-weather-hero__cond">{{weatherSummaryLine}}</text>
      <text wx:if="{{growthHint}}" class="index-weather-hero__hint">{{growthHint}}</text>
    </view>
    <view class="index-weather-hero__sun">☀️</view>
  </view>
  <view wx:else class="index-weather-hero ga-card index-weather-hero--empty" bindtap="goSettings">
    <view class="index-weather-hero__left">
      <text class="index-weather-hero__date">{{heroDate}} · {{weekday}}</text>
      <text class="index-weather-hero__placeholder">保存位置后可在「我」中开启定位，首页将显示本地天气</text>
    </view>
    <view class="index-weather-hero__sun index-weather-hero__sun--muted">🌍</view>
  </view>

  <view class="index-section-head">
    <text class="index-section-head__title">待办事项</text>
  </view>
  <view class="index-todos-row ga-card">
    <view class="index-donut-wrap" bindtap="goPlants">
      <view class="index-donut index-donut--water">
        <text class="index-donut__num">{{waterTodoCount}}</text>
      </view>
      <text class="index-donut__cap">待浇水</text>
    </view>
    <view class="index-donut-wrap" bindtap="goPlants">
      <view class="index-donut index-donut--fert">
        <text class="index-donut__num">{{fertilizeTodoCount}}</text>
      </view>
      <text class="index-donut__cap">待施肥</text>
    </view>
  </view>

  <view class="index-section-head">
    <text class="index-section-head__title">我的植物</text>
    <text class="index-section-head__link" bindtap="goPlants">全部 ›</text>
  </view>
  <scroll-view wx:if="{{plantStrip.length}}" scroll-x class="index-plants-scroll" show-scrollbar="{{false}}">
    <view class="index-plants-scroll__inner">
      <view
        wx:for="{{plantStrip}}"
        wx:key="id"
        class="index-plant-chip"
        data-id="{{item.id}}"
        bindtap="goPlantEdit"
      >
        <view class="index-plant-chip__avatar">{{item.avatarLetter}}</view>
        <text class="index-plant-chip__name">{{item.nickname}}</text>
      </view>
    </view>
  </scroll-view>
  <view wx:else class="index-plants-empty ga-card" bindtap="goAdd">
    <text>还没有植物，点此处添加</text>
  </view>

  <text class="index-section-head__title index-section-head__title--solo">常用工具</text>
  <view class="index-tools ga-card">
    <view class="index-tool" bindtap="onIdentify">
      <text class="index-tool__icon">🌼</text>
      <text class="index-tool__label">植物识别</text>
    </view>
    <view class="index-tool" bindtap="onDiagnosePhoto">
      <text class="index-tool__icon">🪴</text>
      <text class="index-tool__label">土壤识别</text>
    </view>
    <view class="index-tool" bindtap="onDiagnoseSymptom">
      <text class="index-tool__icon">🐛</text>
      <text class="index-tool__label">病虫害诊断</text>
    </view>
  </view>

  <block wx:if="{{tasks.length > 0}}">
    <text class="index-section-head__title index-section-head__title--solo">今日任务</text>
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="index-task ga-card">
        <view class="index-task__head">
          <view class="index-badge index-badge--{{item.typeClass}}">{{item.displayType}}</view>
          <text class="index-task__time">{{item.displayTime}}</text>
        </view>
        <text class="index-task__plant">{{item.plantNickname}}</text>
        <view class="index-task__foot">
          <view class="index-pill index-pill--primary" data-id="{{item.id}}" bindtap="onComplete">标记完成</view>
          <view class="index-pill index-pill--quiet" data-id="{{item.id}}" bindtap="onSkip">跳过</view>
        </view>
      </view>
    </block>
  </block>
</view>
