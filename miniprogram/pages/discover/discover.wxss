.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 24rpx 0;
}

.card {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #2e7d32;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.card-summary {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.45;
}
