<view class="ga-page plants">
  <view class="plants-toolbar ga-card">
    <view class="plants-search">
      <text class="plants-search__icon">🔍</text>
      <input
        class="plants-search__input"
        type="text"
        placeholder="搜索我的植物"
        confirm-type="search"
        value="{{searchQuery}}"
        bindinput="onSearchInput"
      />
    </view>
    <view class="plants-toolbar__add" bindtap="goAdd">＋</view>
  </view>

  <view wx:if="{{needLocationTip}}" class="plants-loc-hint ga-card" bindtap="goSettings">
    <text class="plants-loc-hint__text">开启定位后，首页与计划会结合当地天气微调浇水节奏</text>
    <text class="plants-loc-hint__go">去「我」设置 ›</text>
  </view>

  <view wx:if="{{displayPlants.length === 0}}" class="plants-empty ga-card">
    <text class="plants-empty__title">{{searchQuery ? '没有匹配的植物' : '还没有植物'}}</text>
    <text class="plants-empty__hint">{{searchQuery ? '换个关键词试试' : '点击右上角 ＋ 添加'}}</text>
  </view>

  <block wx:for="{{displayPlants}}" wx:key="id">
    <view class="plants-card ga-card">
      <view class="plants-card__main">
        <view class="plants-avatar">{{item.avatarLetter}}</view>
        <view class="plants-card__body">
          <text class="plants-card__name">{{item.nickname}}</text>
          <text class="plants-card__species">{{item.speciesLabel}}</text>
        </view>
      </view>
      <view class="plants-card__actions">
        <view class="plants-pill plants-pill--outline" data-id="{{item.id}}" bindtap="goPlan">计划</view>
        <view class="plants-pill plants-pill--outline" data-id="{{item.id}}" bindtap="goEdit">编辑</view>
        <view class="plants-pill plants-pill--danger" data-id="{{item.id}}" bindtap="onDelete">删除</view>
      </view>
    </view>
  </block>
</view>
