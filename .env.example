DATABASE_URL="postgresql://greenai:greenai@localhost:5432/greenai"
JWT_SECRET="change-me-min-32-chars-please-use-random"
WECHAT_APPID="your-mini-program-appid"
WECHAT_SECRET="your-mini-program-secret"
CRON_HMAC_SECRET="change-me-cron-shared-secret"
SUBSCRIBE_TEMPLATE_ID="your-approved-template-id"
PORT=3000

# --- Optional: 百度 AI 植物识别（小程序「拍照识别」；两者都填才启用）---
# BAIDU_API_KEY=""
# BAIDU_SECRET_KEY=""

# --- Optional: deploy/docker-compose.prod.yml (API + Postgres) ---
# Strong password for the Postgres container (must match DATABASE_URL password).
# POSTGRES_PASSWORD="your-strong-password"
# When the API runs in that Compose stack, use hostname `db` (not localhost):
# DATABASE_URL="postgresql://greenai:your-strong-password@db:5432/greenai"
# Host port published for the API (default 3000).
# API_PUBLISH_PORT=3000
